JIRA_BASE_URL=https://your-domain.atlassian.net

# Recommended for Atlassian Cloud.
JIRA_EMAIL=
JIRA_API_TOKEN=

# Alternative bearer auth.
JIRA_BEARER_TOKEN=

# Alternative browser/session cookie auth.
JIRA_SESSION_TOKEN=
JIRA_COOKIE_NAME=tenant.session.token

# Optional defaults.
JIRA_ISSUE_KEY=
JIRA_MAX_IMAGE_MB=8
JIRA_REQUEST_TIMEOUT_MS=30000
JIRA_BROWSER_PROFILE_DIR=.auth/browser-profile
JIRA_STORAGE_STATE=.auth/jira-storage-state.json
JIRA_FORCE_LOGIN=false
JIRA_CDP_URL=http://127.0.0.1:9222
JIRA_CDP_PORT=9222
JIRA_LAUNCH_BROWSER=msedge
JIRA_USE_DEFAULT_BROWSER_PROFILE=true
JIRA_CLOSE_EXISTING_BROWSER=true
